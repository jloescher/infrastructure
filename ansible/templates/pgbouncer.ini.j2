; PgBouncer configuration
; Generated by Ansible - do not edit manually

[databases]
{% for db_key, db in databases.items() %}
; {{ db.description }}
{{ db.name }} = host={{ pgbouncer_host }} port=5000 dbname={{ db.name }}
{{ db.name }}_read = host={{ pgbouncer_host }} port=5001 dbname={{ db.name }}
{% endfor %}

[pgbouncer]
listen_addr = {{ pgbouncer_listen_addr }}
listen_port = 6432
unix_socket_dir = /var/run/postgresql
auth_type = scram-sha-256
auth_file = /etc/pgbouncer/userlist.txt

; Transaction pooling - optimal for web apps
pool_mode = {{ pgbouncer.pool_mode }}

; Connection limits
max_client_conn = {{ pgbouncer.max_client_conn }}
default_pool_size = {{ pgbouncer.default_pool_size }}
min_pool_size = {{ pgbouncer.min_pool_size }}
reserve_pool_size = {{ pgbouncer.reserve_pool_size }}
reserve_pool_timeout = {{ pgbouncer.reserve_pool_timeout }}

; Server settings
server_reset_query = {{ pgbouncer.server_reset_query }}
server_check_query = {{ pgbouncer.server_check_query }}
server_check_delay = {{ pgbouncer.server_check_delay }}
server_lifetime = {{ pgbouncer.server_lifetime }}
server_idle_timeout = {{ pgbouncer.server_idle_timeout }}

; Query timeout
query_timeout = {{ pgbouncer.query_timeout }}
query_wait_timeout = {{ pgbouncer.query_wait_timeout }}

; Required for pgx driver
ignore_startup_parameters = {{ pgbouncer.ignore_startup_parameters }}

; Logging
log_connections = 0
log_disconnections = 0
log_pooler_errors = 1
stats_period = 60

; Admin
admin_users = db_admin
stats_users = db_admin

; TLS
client_tls_sslmode = disable