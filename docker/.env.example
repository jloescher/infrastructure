# Infrastructure Dashboard Configuration
# Copy this file to .env and fill in your values

# PostgreSQL Configuration
PG_HOST=100.102.220.16
PG_PORT=5000
PG_USER=patroni_superuser
PG_PASSWORD=your_pg_password_here

# Redis Configuration
REDIS_HOST=100.126.103.51
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# Dashboard Authentication
DASHBOARD_USER=admin
DASHBOARD_PASS=your_dashboard_password_here
SECRET_KEY=your_secret_key_here

# GitHub Integration (optional)
GITHUB_TOKEN=your_github_token_here

# Cloudflare Integration (optional)
CF_API_TOKEN=your_cloudflare_api_token_here

# Grafana Configuration
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password_here

# Tailscale Auth Key (for tailscale sidecar, optional)
TS_AUTHKEY=your_tailscale_auth_key_here