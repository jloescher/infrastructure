{
  "id": null,
  "uid": "loki-logs-quantyra",
  "title": "Quantyra - Logs (Loki)",
  "tags": ["loki", "logs", "quantyra"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 0,
  "refresh": "30s",
  "panels": [
    {
      "title": "Log Rate by Host",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (host) (rate({job=~\".+\"}[5m]))",
          "legendFormat": "{{host}}",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "logs/s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "title": "Log Rate by Job",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum by (job) (rate({job=~\".+\"}[5m]))",
          "legendFormat": "{{job}}",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "logs/s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "title": "Real Errors",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 6},
      "targets": [
        {
          "expr": "sum(count_over_time({filename=~\".*error\\\\.log|.*err\"} [1h])) + sum(count_over_time({job=\"syslog\"} |~ \"(?i)(error|fatal|panic|critical):\" [1h]))",
          "legendFormat": "Errors",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]
          },
          "description": "Actual errors from error.log files and syslog error-level messages"
        }
      }
    },
    {
      "title": "Fail2Ban Banned",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 6},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"auth\"} |= \"Ban\" [1h]))",
          "legendFormat": "Banned IPs",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "green", "value": 1}
            ]
          },
          "description": "IPs banned by Fail2Ban (good!)"
        }
      }
    },
    {
      "title": "SSH Brute Force",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 6},
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"auth\"} |= \"Failed password\" [1h]))",
          "legendFormat": "Attempts",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 200}
            ]
          },
          "description": "SSH brute force attempts - Fail2Ban is handling these"
        }
      }
    },
    {
      "title": "Total Logs (1h)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 6},
      "targets": [
        {
          "expr": "sum(count_over_time({job=~\".+\"} [1h]))",
          "legendFormat": "Total",
          "refId": "A",
          "datasource": "Loki"
        }
      ]
    },
    {
      "title": "Active Hosts",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 6},
      "targets": [
        {
          "expr": "count(count by (host) (count_over_time({job=~\".+\"} [5m])))",
          "legendFormat": "Hosts",
          "refId": "A",
          "datasource": "Loki"
        }
      ]
    },
    {
      "title": "Active Jobs",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 6},
      "targets": [
        {
          "expr": "count(count by (job) (count_over_time({job=~\".+\"} [5m])))",
          "legendFormat": "Jobs",
          "refId": "A",
          "datasource": "Loki"
        }
      ]
    },
    {
      "title": "Recent Syslog",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "targets": [
        {
          "expr": "{job=\"syslog\"}",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    },
    {
      "title": "Real Errors",
      "type": "logs",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "targets": [
        {
          "expr": "{filename=~\".*error\\\\.log|.*err\"}",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    },
    {
      "title": "Docker Service Logs",
      "type": "logs",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 18},
      "targets": [
        {
          "expr": "{job=\"syslog\"} |= \"docker\"",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "Application Logs",
      "type": "logs",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 18},
      "targets": [
        {
          "expr": "{job=\"syslog\"} |= \"dokploy\"",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "PostgreSQL Logs",
      "type": "logs",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 18},
      "targets": [
        {
          "expr": "{job=\"postgresql\"}",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "Auth Logs",
      "type": "logs",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "{job=\"auth\"}",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "HAProxy Logs",
      "type": "logs",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 24},
      "targets": [
        {
          "expr": "{job=\"haproxy\"}",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "Top Hosts by Log Volume",
      "type": "piechart",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 30},
      "targets": [
        {
          "expr": "topk(10, sum by (host) (count_over_time({job=~\".+\"} [1h])))",
          "legendFormat": "{{host}}",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      }
    },
    {
      "title": "Top Jobs by Log Volume",
      "type": "piechart",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 30},
      "targets": [
        {
          "expr": "topk(10, sum by (job) (count_over_time({job=~\".+\"} [1h])))",
          "legendFormat": "{{job}}",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      }
    },
    {
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 30},
      "targets": [
        {
          "expr": "sum by (host) (rate({job=~\".+\", job!=\"syslog\"} |~ \"(?i)(error|fatal|panic|critical)\" [5m]))",
          "legendFormat": "{{host}}",
          "refId": "A",
          "datasource": "Loki"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "errors/s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    }
  ]
}
