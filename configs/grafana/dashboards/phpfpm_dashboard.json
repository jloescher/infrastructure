{
  "id": null,
  "uid": "phpfpm-quantyra",
  "title": "Quantyra - PHP-FPM Metrics",
  "tags": ["php-fpm", "quantyra"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 0,
  "refresh": "30s",
  "panels": [
    {
      "title": "Active Processes",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "phpfpm_processes_total{state=\"active\"}",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Idle Processes",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "phpfpm_processes_total{state=\"idle\"}",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Total Connections",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "phpfpm_accepted_connections_total",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Max Children Reached",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "phpfpm_max_children_reached_total",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Process Distribution",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "phpfpm_processes_total{state=\"active\"}",
          "legendFormat": "{{instance}} Active",
          "refId": "A",
          "datasource": "Prometheus"
        },
        {
          "expr": "phpfpm_processes_total{state=\"idle\"}",
          "legendFormat": "{{instance}} Idle",
          "refId": "B",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Connection Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "rate(phpfpm_accepted_connections_total[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    }
  ]
}
