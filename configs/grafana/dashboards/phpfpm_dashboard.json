{
  "id": null,
  "uid": "phpfpm-quantyra",
  "title": "Quantyra - PHP-FPM Metrics",
  "tags": ["php-fpm", "quantyra"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 0,
  "refresh": "30s",
  "panels": [
    {
      "title": "Active Processes",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (node) (phpfpm_processes_total{state=\"active\"})",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Idle Processes",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sum by (node) (phpfpm_processes_total{state=\"idle\"})",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Connections/sec",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum by (node) (rate(phpfpm_accepted_connections_total[5m]))",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": "Prometheus",
          "unit": "req/s"
        }
      ]
    },
    {
      "title": "Max Children Reached",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "sum by (node) (phpfpm_max_children_reached_total)",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Process Distribution",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum by (node) (phpfpm_processes_total{state=\"active\"})",
          "legendFormat": "{{node}} Active",
          "refId": "A",
          "datasource": "Prometheus"
        },
        {
          "expr": "sum by (node) (phpfpm_processes_total{state=\"idle\"})",
          "legendFormat": "{{node}} Idle",
          "refId": "B",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Connection Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "sum by (node) (rate(phpfpm_accepted_connections_total[5m]))",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    }
  ]
}
