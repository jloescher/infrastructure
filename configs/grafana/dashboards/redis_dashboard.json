{
  "title": "Quantyra - Redis",
  "tags": [
    "redis",
    "quantyra"
  ],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 0,
  "refresh": "30s",
  "panels": [
    {
      "title": "Redis Status",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (node) (redis_up)",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Connected Clients",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (node) (redis_connected_clients)",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "avg by (node) (redis_memory_used_bytes / redis_memory_max_bytes) * 100",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      }
    },
    {
      "title": "Replication Status",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "max by (node) (redis_connected_slaves)",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Memory Usage (Bytes)",
      "type": "graph",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum by (node) (redis_memory_used_bytes)",
          "legendFormat": "{{node}} Used",
          "refId": "A",
          "datasource": "Prometheus"
        },
        {
          "expr": "sum by (node) (redis_memory_max_bytes)",
          "legendFormat": "{{node}} Max",
          "refId": "B",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Operations per Second",
      "type": "graph",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum by (node) (rate(redis_commands_processed_total[5m]))",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Key Count",
      "type": "graph",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "expr": "sum(redis_db_keys) by (instance, db)",
          "legendFormat": "{{node}} - {{db}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Hit/Miss Ratio",
      "type": "graph",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "targets": [
        {
          "expr": "sum by (node) (rate(redis_keyspace_hits_total[5m]))",
          "legendFormat": "{{node}} Hits",
          "refId": "A",
          "datasource": "Prometheus"
        },
        {
          "expr": "sum by (node) (rate(redis_keyspace_misses_total[5m]))",
          "legendFormat": "{{node}} Misses",
          "refId": "B",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Connected Slaves",
      "type": "graph",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "max by (node) (redis_connected_slaves)",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Expired Keys",
      "type": "graph",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (node) (rate(redis_expired_keys_total[5m]))",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    }
  ],
  "uid": "redis-quantyra",
  "id": null
}
