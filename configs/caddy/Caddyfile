# =====================================================
# MEDIA.LZRCDN.COM - Media Proxy Subdomain
# =====================================================
media.lzrcdn.com {
    tls {
        protocols tls1.2 tls1.3
    }

    # Media-specific headers (allow caching)
    header {
        X-Content-Type-Options nosniff
        -Server
        # Cache headers set by upstream
    }

    # All media requests go to app backend
    handle {
        import app_proxy
    }
}