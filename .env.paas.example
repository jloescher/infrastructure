# Quantyra PaaS Configuration
# Copy this file to .env and fill in your values

# === Required ===
# GitHub Personal Access Token with gist scope
GITHUB_TOKEN=ghp_your_token_here

# === Optional ===
# Existing Gist ID to restore configuration from
# Leave empty to create a new Gist on first run
GIST_ID=

# Dashboard credentials (will be generated if not set)
DASHBOARD_USER=admin
DASHBOARD_PASS=

# === External Infrastructure (Optional) ===
# PostgreSQL/Patroni cluster (for managing app databases)
PG_HOST=100.102.220.16
PG_PORT=5000
PG_USER=patroni_superuser
PG_PASSWORD=

# Redis cluster
REDIS_HOST=100.126.103.51
REDIS_PASSWORD=

# Cloudflare API (for domain provisioning)
CLOUDFLARE_API_TOKEN=

# === Advanced ===
# Database path inside container (default: /data/paas.db)
# PAAS_DATABASE_PATH=/data/paas.db

# Encryption key path (default: /data/vault.key)
# PAAS_KEY_PATH=/data/vault.key