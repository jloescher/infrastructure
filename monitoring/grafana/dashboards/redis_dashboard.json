{
  "dashboard": {
    "title": "Quantyra - Redis",
    "tags": ["redis", "quantyra"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "30s",
    "panels": [
      {
        "title": "Redis Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "redis_up",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Connected Clients",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "redis_connected_clients",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Memory Usage",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "(redis_memory_used_bytes / redis_memory_max_bytes) * 100",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "max": 100,
            "min": 0,
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 85}
              ]
            }
          }
        }
      },
      {
        "title": "Replication Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "redis_connected_slaves",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Memory Usage (Bytes)",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "redis_memory_used_bytes",
            "legendFormat": "{{instance}} Used",
            "refId": "A"
          },
          {
            "expr": "redis_memory_max_bytes",
            "legendFormat": "{{instance}} Max",
            "refId": "B"
          }
        ]
      },
      {
        "title": "Operations per Second",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "rate(redis_commands_processed_total[5m])",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Key Count",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 10},
        "targets": [
          {
            "expr": "sum(redis_db_keys) by (instance, db)",
            "legendFormat": "{{instance}} - {{db}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Hit/Miss Ratio",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 10},
        "targets": [
          {
            "expr": "rate(redis_keyspace_hits_total[5m])",
            "legendFormat": "{{instance}} Hits",
            "refId": "A"
          },
          {
            "expr": "rate(redis_keyspace_misses_total[5m])",
            "legendFormat": "{{instance}} Misses",
            "refId": "B"
          }
        ]
      },
      {
        "title": "Connected Slaves",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "redis_connected_slaves",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Expired Keys",
        "type": "graph",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "rate(redis_expired_keys_total[5m])",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ]
      }
    ]
  },
  "overwrite": true
}